{
  "name": "@tomasward/whoop-cli",
  "publishConfig": {
    "access": "public"
  },
  "version": "2.5.0",
  "description": "Agent-first CLI for the WHOOP API",
  "type": "module",
  "bin": {
    "whoop-cli": "./dist/index.js",
    "whoop": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "whoop",
    "health",
    "fitness",
    "cli",
    "api",
    "hrv",
    "recovery",
    "sleep",
    "strain",
    "insights",
    "trends"
  ],
  "author": "Tomas Ward",
  "repository": {
    "type": "git",
    "url": "https://github.com/TomasWard1/whoop-cli.git"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/__tests__/**",
    "SKILL.md",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
